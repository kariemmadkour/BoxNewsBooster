{
  "name": "functions",
  "private": true,
  "version": "0.0.0",
  "type": "commonjs",
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions,firestore,pubsub,tasks",
    "shell": "npm run build && firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "lint": "tsc --noEmit",
    "seed:keywords": "npm run build && node lib/scripts/seedKeywords.js",
    "grant:role": "npm run build && node lib/scripts/grantRole.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.70.0",
    "@google-cloud/pubsub": "^5.3.1",
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.1.0",
    "google-trends-api": "^4.9.2",
    "rss-parser": "^3.13.0",
    "twitter-api-v2": "^1.29.0"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  }
}
