#   firebase functions:secrets:set GNEWS_API_KEY
#   firebase functions:secrets:set ANTHROPIC_API_KEY
# This file documents the required names only -- do not put real values here.
NEWS_API_KEY=
GNEWS_API_KEY=
ANTHROPIC_API_KEY=
