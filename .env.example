# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase client config -- these are public identifiers, not secrets
# (safe to ship in the built bundle). Get them from Firebase Console >
# Project Settings > General > Your apps > Web app > SDK setup and config.
VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="boxnewsbooster.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="boxnewsbooster"
VITE_FIREBASE_STORAGE_BUCKET="boxnewsbooster.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="810496075576"
VITE_FIREBASE_APP_ID="MY_FIREBASE_APP_ID"
VITE_FUNCTIONS_REGION="us-central1"

# App Check reCAPTCHA v3 site key -- public identifier, not a secret.
# Get it from Firebase Console > App Check > register your web app.
VITE_RECAPTCHA_SITE_KEY="MY_RECAPTCHA_SITE_KEY"
