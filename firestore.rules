rules_version = '2';

// All reads/writes go through Cloud Functions (Admin SDK, which bypasses
// these rules entirely). Direct client access is denied on purpose --
// there is no benefit to opening the cache collections to clients, only risk.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
